+    Use char because int might match the return type of a GCC
+@@ -29640,6 +29644,8 @@
+ LIBS="-lXext  $LIBS"
+ cat confdefs.h - <<_ACEOF >conftest.$ac_ext
+ /* end confdefs.h.  */
++
++#include <X11/extensions/shape.h>
+
+ /* Override any GCC internal prototype to avoid an error.
+    Use char because int might match the return type of a GCC
+@@ -29682,6 +29688,8 @@
+ LIBS="-lXt  $LIBS"
+ cat confdefs.h - <<_ACEOF >conftest.$ac_ext
+ /* end confdefs.h.  */
